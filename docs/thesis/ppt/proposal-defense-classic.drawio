        </mxCell>
        <mxCell id="16" value="结构错误如何显式控制" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=24;fontStyle=1;fontColor=#1F497D;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="150.0" y="558.0" width="460.0" height="40.0" as="geometry" />
        </mxCell>
        <mxCell id="17" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="690.0" y="600.0" width="120.0" height="10.0" as="geometry" />
        </mxCell>
        <mxCell id="18" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#E2E8F0;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="850.0" y="530.0" width="930.0" height="190.0" as="geometry" />
        </mxCell>
        <mxCell id="19" value="通过布局热图、结构监督和辅助探针约束部件比例、位置关系和包围结构，降低“看起来像字但结构不对”的风险。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="885.0" y="568.0" width="860.0" height="120.0" as="geometry" />
