        </mxCell>
        <mxCell id="14" value="文本部件与图像部件在接口层和编码层同时保持兼容，避免训练过程出现条件割裂。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
