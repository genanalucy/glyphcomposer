        <mxCell id="5" value="06 核心方法设计" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
