          <mxGeometry x="1540.0" y="385.0" width="72.0" height="56.0" as="geometry" />
        </mxCell>
        <mxCell id="32" value="评测与扩展" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=24;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="1620.0" y="390.0" width="290.0" height="40.0" as="geometry" />
        </mxCell>
        <mxCell id="33" value="整字留出评测&#10;加少量 OOV/古壮字扩展验证" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
