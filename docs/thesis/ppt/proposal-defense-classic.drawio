        <mxCell id="11" value="创新点" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="144.0" y="318.0" width="712.0" height="36.0" as="geometry" />
        </mxCell>
        <mxCell id="12" value="1. 把文本部件输入和图像部件输入统一到同一条件接口中。&#10;&#10;2. 将结构标签、布局热图和结构监督显式引入生成过程，而不是完全依赖模型隐式学习。&#10;&#10;3. 将整字留出切分放到更关键的位置，用组合泛化而不是单纯随机切分来检验方法是否成立。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="144.0" y="362.0" width="712.0" height="536.0" as="geometry" />
        </mxCell>
        <mxCell id="13" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#E2E8F0;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="940.0" y="300.0" width="840.0" height="620.0" as="geometry" />
        </mxCell>
        <mxCell id="14" value="可行性基础" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="964.0" y="318.0" width="792.0" height="36.0" as="geometry" />
        </mxCell>
        <mxCell id="15" value="数据来源明确：公开字体与拆字表可以支持自动构造首版样本。&#10;&#10;研究路线可控：先做条件 U-Net 基线，再推进到 VAE 与潜空间扩散。&#10;&#10;工程基础已具备：仓库中已有 build_dataset、train_baseline、train_diffusion、run_demo 等脚本，说明这项工作不是从零起步。&#10;&#10;风险应对清楚：先低分辨率跑通链路，再逐步提升标准分辨率，并把 OOV 验证控制在小样本轻量适配范围内。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="964.0" y="362.0" width="792.0" height="536.0" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
