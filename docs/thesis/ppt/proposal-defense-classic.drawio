        </mxCell>
        <mxCell id="9" value="真正困难的地方，不是“能不能出图”，而是“是否学会怎样组合”" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=25;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
