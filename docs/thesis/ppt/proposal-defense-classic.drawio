  <diagram id="研究意义" name="研究意义">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F7F8FA;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="0.0" width="1920.0" height="1080.0" as="geometry" />
        </mxCell>
        <mxCell id="3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1F497D;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="0.0" width="1920.0" height="120.0" as="geometry" />
        </mxCell>
        <mxCell id="4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="120.0" width="1920.0" height="6.0" as="geometry" />
        </mxCell>
        <mxCell id="5" value="02 研究意义与应用场景" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="0.0" width="1920.0" height="120.0" as="geometry" />
        </mxCell>
        <mxCell id="6" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="1040.0" width="1920.0" height="4.0" as="geometry" />
        </mxCell>
        <mxCell id="7" value="2026 年 4 月" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;fontSize=14;fontStyle=0;fontColor=#4A5568;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="1560.0" y="1042.0" width="270.0" height="30.0" as="geometry" />
        </mxCell>
        <mxCell id="8" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="120.0" y="182.0" width="10.0" height="38.0" as="geometry" />
        </mxCell>
        <mxCell id="9" value="方法研究先行，应用价值作为自然外延" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=25;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="148.0" y="180.0" width="900.0" height="44.0" as="geometry" />
        </mxCell>
        <mxCell id="10" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E2E8F0;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="120.0" y="300.0" width="520.0" height="420.0" as="geometry" />
        </mxCell>
        <mxCell id="11" value="字库补字与字体设计" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="144.0" y="318.0" width="472.0" height="36.0" as="geometry" />
        </mxCell>
        <mxCell id="12" value="在目标字符缺失时，为字体设计和快速试排提供结构正确的候选字形，而不是完全依赖人工描绘。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="144.0" y="362.0" width="472.0" height="336.0" as="geometry" />
        </mxCell>
        <mxCell id="13" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E2E8F0;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="700.0" y="300.0" width="520.0" height="420.0" as="geometry" />
        </mxCell>
        <mxCell id="14" value="古籍整理与异体字数字化" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="724.0" y="318.0" width="472.0" height="36.0" as="geometry" />
        </mxCell>
        <mxCell id="15" value="许多字符没有稳定编码入口，但研究者通常能给出构形描述或局部部件图像，这使统一条件接口有了真实使用场景。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="724.0" y="362.0" width="472.0" height="336.0" as="geometry" />
        </mxCell>
        <mxCell id="16" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E2E8F0;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1280.0" y="300.0" width="520.0" height="420.0" as="geometry" />
        </mxCell>
        <mxCell id="17" value="低资源字符处理" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="1304.0" y="318.0" width="472.0" height="36.0" as="geometry" />
        </mxCell>
        <mxCell id="18" value="若模型能够在有限样本下维持结构约束，就有机会把现代汉字主任务平滑延伸到 OOV 字符、古壮字等边缘场景。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="1304.0" y="362.0" width="472.0" height="336.0" as="geometry" />
        </mxCell>
        <mxCell id="19" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#E2E8F0;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="200.0" y="780.0" width="1520.0" height="150.0" as="geometry" />
        </mxCell>
        <mxCell id="20" value="研究定位" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="224.0" y="798.0" width="1472.0" height="36.0" as="geometry" />
        </mxCell>
        <mxCell id="21" value="本课题首先讨论的是“部件与结构条件如何驱动整字生成”，不是把系统包装成已经成熟落地的工程产品。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="224.0" y="842.0" width="1472.0" height="66.0" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="研究现状" name="研究现状">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F7F8FA;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="0.0" width="1920.0" height="1080.0" as="geometry" />
        </mxCell>
        <mxCell id="3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1F497D;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="0.0" width="1920.0" height="120.0" as="geometry" />
        </mxCell>
        <mxCell id="4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="120.0" width="1920.0" height="6.0" as="geometry" />
        </mxCell>
        <mxCell id="5" value="03 国内外研究现状与研究空缺" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="0.0" width="1920.0" height="120.0" as="geometry" />
        </mxCell>
        <mxCell id="6" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="1040.0" width="1920.0" height="4.0" as="geometry" />
        </mxCell>
        <mxCell id="7" value="2026 年 4 月" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;fontSize=14;fontStyle=0;fontColor=#4A5568;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="1560.0" y="1042.0" width="270.0" height="30.0" as="geometry" />
        </mxCell>
        <mxCell id="8" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="120.0" y="182.0" width="10.0" height="38.0" as="geometry" />
        </mxCell>
        <mxCell id="9" value="相关研究已经很多，但尚未自然汇聚成统一任务框架" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=25;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="148.0" y="180.0" width="1040.0" height="44.0" as="geometry" />
        </mxCell>
        <mxCell id="10" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E2E8F0;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="100.0" y="300.0" width="540.0" height="430.0" as="geometry" />
        </mxCell>
        <mxCell id="11" value="部件与结构表征" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="124.0" y="318.0" width="492.0" height="36.0" as="geometry" />
        </mxCell>
        <mxCell id="12" value="零样本汉字识别、显式偏旁编码、IDS 对齐、formation tree 等工作说明：汉字可以被拆解，也值得以结构化方式表示。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="124.0" y="362.0" width="492.0" height="346.0" as="geometry" />
        </mxCell>
        <mxCell id="13" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E2E8F0;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="690.0" y="300.0" width="540.0" height="430.0" as="geometry" />
        </mxCell>
        <mxCell id="14" value="字体迁移与字形生成" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="714.0" y="318.0" width="492.0" height="36.0" as="geometry" />
        </mxCell>
        <mxCell id="15" value="GAN、Transformer 和扩散模型显著提升了字形生成质量，但多数研究默认目标字符身份已知，关注的是风格迁移而非“部件到整字”的组合生成。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="714.0" y="362.0" width="492.0" height="346.0" as="geometry" />
        </mxCell>
        <mxCell id="16" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E2E8F0;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1280.0" y="300.0" width="540.0" height="430.0" as="geometry" />
        </mxCell>
        <mxCell id="17" value="扩散模型与稀有字符处理" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="1304.0" y="318.0" width="492.0" height="36.0" as="geometry" />
        </mxCell>
        <mxCell id="18" value="近年的相关工作证明生成模型能够服务字体合成和低资源字符任务。&#10;&#10;但在这些研究中，结构约束通常还不是最核心的控制信号。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="1304.0" y="362.0" width="492.0" height="346.0" as="geometry" />
        </mxCell>
        <mxCell id="19" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1F497D;strokeColor=#1F497D;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="140.0" y="790.0" width="1640.0" height="145.0" as="geometry" />
        </mxCell>
        <mxCell id="20" value="研究空缺：现有工作分别回答了“如何表示部件”“如何迁移字体风格”“如何提升图像生成质量”，&#10;但还没有形成成熟的“部件 + 结构条件 -&gt; 整字图像”的统一研究框架。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="170.0" y="820.0" width="1580.0" height="90.0" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="任务定义" name="任务定义">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
