        </mxCell>
        <mxCell id="21" value="组合泛化如何被证明" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=24;fontStyle=1;fontColor=#1F497D;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="150.0" y="783.0" width="460.0" height="40.0" as="geometry" />
        </mxCell>
        <mxCell id="22" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="690.0" y="825.0" width="120.0" height="10.0" as="geometry" />
        </mxCell>
        <mxCell id="23" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#E2E8F0;dashed=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="850.0" y="755.0" width="930.0" height="190.0" as="geometry" />
        </mxCell>
        <mxCell id="24" value="把整字留出切分放到关键位置，结合结构正确性分析和典型案例，区分真正泛化与训练样本记忆。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
