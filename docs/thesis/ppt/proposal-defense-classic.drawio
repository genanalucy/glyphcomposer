          <mxGeometry x="120.0" y="305.0" width="520.0" height="190.0" as="geometry" />
        </mxCell>
        <mxCell id="11" value="多模态条件如何统一" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=24;fontStyle=1;fontColor=#1F497D;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="150.0" y="333.0" width="460.0" height="40.0" as="geometry" />
