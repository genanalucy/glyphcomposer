          <mxGeometry x="0.0" y="0.0" width="1920.0" height="1080.0" as="geometry" />
        </mxCell>
        <mxCell id="3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1F497D;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="0.0" width="1920.0" height="120.0" as="geometry" />
