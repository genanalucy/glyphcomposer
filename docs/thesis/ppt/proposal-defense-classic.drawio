          <mxGeometry x="200.0" y="780.0" width="1520.0" height="140.0" as="geometry" />
        </mxCell>
        <mxCell id="35" value="推进原则" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="224.0" y="798.0" width="1472.0" height="36.0" as="geometry" />
        </mxCell>
        <mxCell id="36" value="主任务以现代汉字为核心，OOV 或古壮字只作为方法外延验证。研究路线优先保证问题定义清楚、数据协议稳定和基线可复现。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=0;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="224.0" y="842.0" width="1472.0" height="56.0" as="geometry" />
