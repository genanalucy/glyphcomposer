        <mxCell id="4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="120.0" width="1920.0" height="6.0" as="geometry" />
        </mxCell>
        <mxCell id="5" value="04 任务定义与研究目标" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="0.0" width="1920.0" height="120.0" as="geometry" />
        </mxCell>
        <mxCell id="6" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="0.0" y="1040.0" width="1920.0" height="4.0" as="geometry" />
        </mxCell>
        <mxCell id="7" value="2026 年 4 月" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;fontSize=14;fontStyle=0;fontColor=#4A5568;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="1560.0" y="1042.0" width="270.0" height="30.0" as="geometry" />
        </mxCell>
        <mxCell id="8" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="120.0" y="184.0" width="10.0" height="38.0" as="geometry" />
        </mxCell>
        <mxCell id="9" value="输入部件和结构条件，输出完整字形图像" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=25;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="148.0" y="182.0" width="850.0" height="44.0" as="geometry" />
        </mxCell>
        <mxCell id="10" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=#C9A84C;dashed=0;arcSize=10;" vertex="1" parent="1">
